# =============================================================================
# Wayly — Environment Variables (example)
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in values for local development.
# Rules:
#   - Anything the browser needs MUST be prefixed NEXT_PUBLIC_ and be NON-secret.
#   - Everything else is backend-only (apps/api) and must never reach the client.
#   - All variables are validated at boot via @wayly/validation (added in M1).
#   - In M0, mock flags default ON so the app runs without real provider keys.
# =============================================================================

# ----------------------------------------------------------------------------
# Core            (backend secrets + frontend public URLs)
# ----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-strong-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
AUTH_COOKIE_NAME=wayly_refresh
PASSWORD_RESET_TTL=1h
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# Frontend (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Database        (backend only) — PostgreSQL 16 + PostGIS
# ----------------------------------------------------------------------------
# Local Docker example (do not commit real hosted URLs or passwords):
# DATABASE_URL=postgresql://wayly:wayly@localhost:5432/wayly?schema=public
# Production/staging placeholder shape only:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
# Used by Prisma migrate for safe migration diffing (local example commented above).
SHADOW_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_shadow?schema=public

# ----------------------------------------------------------------------------
# Redis           (backend only) — cache / sessions / queues / ws scaling
# ----------------------------------------------------------------------------
REDIS_URL=redis://HOST:PORT

# ----------------------------------------------------------------------------
# Stripe          (backend secrets; publishable key is public)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------------------------
# KYC             (backend only) — Sumsub + phone OTP (Twilio Verify)
# ----------------------------------------------------------------------------
KYC_PROVIDER=mock           # mock | sumsub
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
OTP_PROVIDER=mock           # mock | twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ----------------------------------------------------------------------------
# Maps            (server token is secret; restricted public token for client)
# ----------------------------------------------------------------------------
MAPS_PROVIDER=mapbox        # mapbox
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# ----------------------------------------------------------------------------
# Notifications   (backend FCM admin + email; web Firebase config is public)
# ----------------------------------------------------------------------------
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_CONFIG=
RESEND_API_KEY=
EMAIL_FROM=no-reply@wayly.app

# ----------------------------------------------------------------------------
# Storage         (backend only) — S3-compatible (AWS S3 / Cloudflare R2)
# ----------------------------------------------------------------------------
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ----------------------------------------------------------------------------
# Monitoring      (backend + frontend public DSN)
# ----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# Mock flags      (backend only) — keep ON until real providers are wired
# ----------------------------------------------------------------------------
MOCK_KYC=true
MOCK_OTP=true
MOCK_PAYMENTS=true
MOCK_PUSH=true

# ----------------------------------------------------------------------------
# Demo seed       (local/dev only — see docs/security-and-secrets-checkpoint.md)
# Never commit real passwords. Never use placeholder passwords on hosted DBs.
# ----------------------------------------------------------------------------
# DEMO_ADMIN_EMAIL=admin@wayly.demo
# DEMO_ADMIN_PASSWORD=
# DEMO_USER_PASSWORD=
# ALLOW_DEMO_SEED=
# DEMO_USERS_PASSWORD=

# ----------------------------------------------------------------------------
# Admin seed      (optional; used only by `prisma db seed`, not app boot)
# ----------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Wayly Admin
