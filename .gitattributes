# Normalize line endings to LF across all platforms to keep diffs and tooling
# (eslint, prettier, husky) consistent on Windows, macOS, and Linux.
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Treat common binaries as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
