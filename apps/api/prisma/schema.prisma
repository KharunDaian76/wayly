// Wayly — Prisma schema.
//
// M1: User, RefreshToken, PasswordResetToken.
// M2 Batch 1: KycVerification (provider integration lands in a later batch).
// M4 Batch 1: DeliveryOrder foundation (API/UI land in later batches).
// Notification foundation (routes/dispatch land in a later batch).
// Chat foundation (routes/WebSocket land in a later batch).
// Payment/escrow foundation (routes/Stripe land in a later batch).
// Wayler availability / trip listing foundation (routes/discovery UI land in a later batch).
// Wayler daily work access pass foundation (routes/paywall gating land in a later batch).
// Dispute/arbitration foundation (routes/admin UI land in a later batch).
//
// PostGIS is enabled because local city-delivery feed/search relies on
// geographic radius queries (geography(Point)) from M4/M5.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// --- Enums (mirror @wayly/types) ---------------------------------------------

// Authorization roles. "Sender"/"Wayler" are contextual modes, NOT roles.
enum UserRole {
  USER
  ADMIN
  ARBITRATOR
}

// KYC verification status; gates core activity until APPROVED (enforced in M2+).
enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

// Delivery request lifecycle (M4 foundation; transitions enforced in later batches).
enum DeliveryOrderStatus {
  DRAFT
  OPEN
  ACCEPTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DISPUTED
}

enum DeliveryOrderType {
  LOCAL
  INTERNATIONAL
}

// How a DeliveryOrder was created (Sender-posted vs converted from availability request).
enum DeliveryOrderSource {
  SENDER_POSTED_ORDER
  WAYLER_AVAILABILITY_REQUEST
}

enum PackageSize {
  SMALL
  MEDIUM
  LARGE
  OVERSIZED
}

// In-app notification severity/category (foundation v1 — in-app only, no push/email).
enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ACTION_REQUIRED
}

enum NotificationEntityType {
  SUPPORT_TICKET
  DELIVERY_ORDER
  WAYLER_AVAILABILITY_REQUEST
  PAYMENT
  DISPUTE
  SYSTEM
}

// Payment intent lifecycle (Stripe/manual processing lands in a later batch).
enum PaymentStatus {
  PENDING
  AUTHORIZED
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  OTHER
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum LedgerEntryType {
  PAYMENT_AUTHORIZED
  ESCROW_HELD
  PLATFORM_FEE_CHARGED
  PAYOUT_CREATED
  PAYOUT_PAID
  REFUND_CREATED
  ADJUSTMENT
}

// Dispute lifecycle (API/arbitrator UI land in a later batch).
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
  CANCELLED
}

enum DisputeReason {
  ITEM_NOT_DELIVERED
  ITEM_DAMAGED
  WRONG_ITEM
  PAYMENT_ISSUE
  SAFETY_CONCERN
  OTHER
}

enum DisputeResolution {
  REFUND_SENDER
  RELEASE_TO_WAYLER
  PARTIAL_REFUND
  NO_ACTION
  OTHER
}

// Wayler-published availability or travel route (API/discovery land in a later batch).
enum WaylerAvailabilityStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum WaylerAvailabilityType {
  LOCAL_AVAILABILITY
  TRIP_ROUTE
}

// Sender request to a published Wayler availability/trip (API/UI land in a later batch).
enum WaylerAvailabilityRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum TripDirection {
  ONE_WAY
  RETURN
  FLEXIBLE
}

// Daily Wayler work access pass lifecycle (paywall/API land in a later batch).
enum WaylerAccessPassStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
  FAILED
}

enum WaylerAccessPassProvider {
  MANUAL
  STRIPE
  OTHER
}

enum SupportTicketCategory {
  GENERAL
  ACCOUNT
  SAFETY
  PAYMENT_STATUS
  ORDER_ISSUE
  BUG_REPORT
  OTHER
}

enum SupportTicketStatus {
  OPEN
  UNDER_REVIEW
  WAITING_FOR_USER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketMessageAuthorRole {
  USER
  ADMIN
}

enum ReviewPartyRole {
  SENDER
  WAYLER
}

// Account moderation status (admin suspend/unsuspend v1).
enum UserAccountStatus {
  ACTIVE
  SUSPENDED
}

// Admin/arbitrator operator audit trail (append-only; v1 actions only).
enum AdminAuditLogAction {
  KYC_APPROVED
  KYC_REJECTED
  DISPUTE_RESOLVED
  USER_SUSPENDED
  USER_UNSUSPENDED
  PAYMENT_MANUAL_REVIEW_MARKED
  PAYMENT_MANUAL_REVIEW_CLEARED
  PAYMENT_REFUND_DECISION_RECORDED
  PAYMENT_RELEASE_DECISION_RECORDED
  ORDER_MANUAL_REVIEW_MARKED
  ORDER_MANUAL_REVIEW_CLEARED
  ORDER_DECISION_RECORDED
  ORDER_RISK_FLAGGED
  ORDER_RISK_CLEARED
}

enum AdminAuditLogTargetType {
  KYC_VERIFICATION
  DISPUTE
  USER
  PAYMENT_INTENT
  DELIVERY_ORDER
}

// Admin metadata-only order review (no lifecycle changes).
enum OrderAdminReviewStatus {
  NONE
  MANUAL_REVIEW
  DECISION_RECORDED
  RISK_FLAGGED
}

enum OrderAdminReviewDecision {
  MONITOR
  ESCALATE_PAYMENT
  ESCALATE_DISPUTE
  NO_ACTION
  OTHER
}

// Admin metadata-only payment review (no real money movement).
enum PaymentAdminReviewStatus {
  NONE
  MANUAL_REVIEW
  REFUND_DECISION_RECORDED
  RELEASE_DECISION_RECORDED
}

enum PaymentAdminReviewDecision {
  RECOMMEND_FULL_REFUND
  RECOMMEND_PARTIAL_REFUND
  RECOMMEND_RELEASE
  NO_ACTION
  OTHER
}

enum AdminAuditLogStatus {
  SUCCESS
  FAILED
}

// --- Models ------------------------------------------------------------------

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  roles        UserRole[] @default([USER])

  // KYC / verification (provider integration lands in M2).
  verified      Boolean   @default(false)
  kycStatus     KycStatus @default(NONE)
  phoneVerified Boolean   @default(false)

  // Payments / payouts (Stripe integration lands in M8).
  stripeCustomerId       String? @unique
  stripeConnectAccountId String? @unique
  connectOnboarded       Boolean @default(false)

  locale  String  @default("en")
  country String?

  // Account moderation (admin suspend/unsuspend v1; ban/delete are out of scope).
  accountStatus    UserAccountStatus @default(ACTIVE)
  suspendedAt      DateTime?
  suspensionReason String?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?
  gdprDeletionRequestedAt DateTime?

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  kycVerifications    KycVerification[]
  sentDeliveryOrders            DeliveryOrder[] @relation("SentDeliveryOrders")
  acceptedDeliveryOrders        DeliveryOrder[] @relation("AcceptedDeliveryOrders")
  proofSubmittedDeliveryOrders  DeliveryOrder[] @relation("ProofSubmittedDeliveryOrders")
  notifications                 Notification[]
  sentConversations             Conversation[] @relation("ConversationSender")
  waylerConversations           Conversation[] @relation("ConversationWayler")
  chatMessages                  ChatMessage[]  @relation("ChatMessageSender")
  paymentIntentsAsPayer         PaymentIntent[] @relation("PaymentIntentPayer")
  paymentIntentsAsPayee         PaymentIntent[] @relation("PaymentIntentPayee")
  payouts                       Payout[]        @relation("PayoutUser")
  ledgerEntries                 LedgerEntry[]   @relation("LedgerEntryUser")
  disputesOpened                Dispute[]       @relation("DisputesOpened")
  disputesAssigned              Dispute[]       @relation("DisputesAssigned")
  disputeMessages               DisputeMessage[] @relation("DisputeMessagesSent")
  disputeEvidence               DisputeEvidence[] @relation("DisputeEvidenceSubmitted")
  waylerAvailabilities          WaylerAvailability[] @relation("WaylerAvailabilities")
  waylerAccessPasses            WaylerAccessPass[]   @relation("WaylerAccessPasses")
  availabilityRequestsSent      WaylerAvailabilityRequest[] @relation("AvailabilityRequestSender")
  availabilityRequestsAsWayler  WaylerAvailabilityRequest[] @relation("AvailabilityRequestWayler")
  adminAuditLogs                AdminAuditLog[]             @relation("AdminAuditLogActor")
  paymentIntentsReviewed        PaymentIntent[]             @relation("PaymentIntentAdminReviewer")
  deliveryOrdersReviewed        DeliveryOrder[]             @relation("DeliveryOrderAdminReviewer")
  supportTickets                SupportTicket[]             @relation("SupportTicketsOwned")
  supportTicketAdminActions     SupportTicket[]             @relation("SupportTicketAdminActions")
  supportTicketMessages         SupportTicketMessage[]      @relation("SupportTicketMessageAuthor")
  reviewsWritten                Review[]                    @relation("ReviewsWritten")
  reviewsReceived               Review[]                    @relation("ReviewsReceived")
  reviewsHidden                 Review[]                    @relation("ReviewHiddenBy")

  @@index([deletedAt])
  @@index([accountStatus])
  @@index([suspendedAt])
  @@map("users")
}

// Refresh tokens are stored ONLY as hashes (never the raw token), with a
// familyId to support rotation + reuse detection.
model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique
  familyId          String    @db.Uuid
  userAgent         String?
  ip                String?
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?   @db.Uuid
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// Password reset tokens are stored ONLY as hashes.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// KYC verification attempts (Sumsub/manual providers wired in a later batch).
// User.kycStatus / User.verified remain denormalized quick-access fields.
model KycVerification {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status              KycStatus @default(PENDING)
  provider            String?
  providerApplicantId String?   @unique
  providerReviewId    String?
  levelName           String?
  country             String?
  documentType        String?
  rejectionReason     String?
  rawProviderPayload  Json?
  submittedAt         DateTime?
  reviewedAt          DateTime?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("kyc_verifications")
}

// P2P delivery request posted by a Sender; optionally accepted by a Wayler (M4 foundation).
model DeliveryOrder {
  id               String              @id @default(uuid()) @db.Uuid
  senderId         String              @db.Uuid
  sender           User                @relation("SentDeliveryOrders", fields: [senderId], references: [id], onDelete: Restrict)
  acceptedWaylerId String?             @db.Uuid
  acceptedWayler   User?               @relation("AcceptedDeliveryOrders", fields: [acceptedWaylerId], references: [id], onDelete: SetNull)
  status           DeliveryOrderStatus @default(DRAFT)
  type             DeliveryOrderType
  sourceType       DeliveryOrderSource @default(SENDER_POSTED_ORDER)
  availabilityRequestId String?        @unique @db.Uuid
  availabilityRequest   WaylerAvailabilityRequest? @relation(fields: [availabilityRequestId], references: [id], onDelete: SetNull)
  title            String
  description      String?
  packageSize      PackageSize?
  packageWeightKg  Decimal?            @db.Decimal(8, 2)

  pickupCountry     String?
  pickupCity        String?
  pickupAddressText String?
  pickupLat         Decimal? @db.Decimal(10, 7)
  pickupLng         Decimal? @db.Decimal(10, 7)

  dropoffCountry     String?
  dropoffCity        String?
  dropoffAddressText String?
  dropoffLat         Decimal? @db.Decimal(10, 7)
  dropoffLng         Decimal? @db.Decimal(10, 7)

  pickupDateFrom   DateTime?
  pickupDateTo     DateTime?
  deliveryDeadline DateTime?

  currency             String   @default("USD")
  offeredRewardAmount  Decimal? @db.Decimal(10, 2)
  escrowRequired       Boolean  @default(true)
  notes                String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  acceptedAt  DateTime?
  cancelledAt DateTime?
  deliveredAt DateTime?

  // Proof-of-delivery metadata (Wayler-submitted; photo/signature URLs in later batches).
  proofNote              String?
  proofConfirmationCode  String?
  proofSubmittedAt       DateTime?
  proofSubmittedById     String?   @db.Uuid
  proofSubmittedBy       User?     @relation("ProofSubmittedDeliveryOrders", fields: [proofSubmittedById], references: [id], onDelete: SetNull)

  // Admin metadata-only review (does not change DeliveryOrder.status or parties).
  adminReviewStatus     OrderAdminReviewStatus     @default(NONE)
  adminReviewDecision   OrderAdminReviewDecision?
  adminReviewNote       String?
  adminReviewAt         DateTime?
  adminReviewByUserId   String?                    @db.Uuid
  adminReviewBy         User?                      @relation("DeliveryOrderAdminReviewer", fields: [adminReviewByUserId], references: [id], onDelete: SetNull)

  conversation           Conversation?
  paymentIntent          PaymentIntent?
  ledgerEntries          LedgerEntry[]
  disputes               Dispute[]
  supportTickets         SupportTicket[]
  reviews                Review[]

  @@index([senderId])
  @@index([acceptedWaylerId])
  @@index([status])
  @@index([type])
  @@index([sourceType])
  @@index([pickupCountry])
  @@index([pickupCity])
  @@index([dropoffCountry])
  @@index([dropoffCity])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([proofSubmittedById])
  @@index([adminReviewStatus])
  @@index([adminReviewAt])
  @@index([adminReviewByUserId])
  @@map("delivery_orders")
}

// In-app notification for a user (in-app only — no email/push/SMS in v1).
model Notification {
  id         String                  @id @default(uuid()) @db.Uuid
  userId     String                  @db.Uuid
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String
  linkHref   String?
  entityType NotificationEntityType?
  entityId   String?                 @db.Uuid
  readAt     DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([userId])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([entityType, entityId])
  @@map("notifications")
}

// Order-based chat between Sender and accepted Wayler (API/WebSocket land in a later batch).
model Conversation {
  id        String        @id @default(uuid()) @db.Uuid
  orderId   String        @unique @db.Uuid
  order     DeliveryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String        @db.Uuid
  sender    User          @relation("ConversationSender", fields: [senderId], references: [id], onDelete: Cascade)
  waylerId  String        @db.Uuid
  wayler    User          @relation("ConversationWayler", fields: [waylerId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages ChatMessage[]

  @@index([senderId])
  @@index([waylerId])
  @@index([orderId])
  @@index([createdAt])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @db.Uuid
  sender         User         @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([readAt])
  @@map("chat_messages")
}

// Per-order payment intent (one per delivery order; escrow/Stripe in later batches).
model PaymentIntent {
  id                String          @id @default(uuid()) @db.Uuid
  orderId           String          @unique @db.Uuid
  order             DeliveryOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payerId           String          @db.Uuid
  payer             User            @relation("PaymentIntentPayer", fields: [payerId], references: [id], onDelete: Restrict)
  payeeId           String?         @db.Uuid
  payee             User?           @relation("PaymentIntentPayee", fields: [payeeId], references: [id], onDelete: SetNull)
  provider          PaymentProvider @default(MANUAL)
  status            PaymentStatus   @default(PENDING)
  currency          String
  amount            Decimal         @db.Decimal(12, 2)
  platformFeeAmount Decimal?        @db.Decimal(12, 2)
  escrowAmount      Decimal?        @db.Decimal(12, 2)
  providerPaymentId String?
  authorizedAt      DateTime?
  escrowedAt        DateTime?
  releasedAt        DateTime?
  refundedAt        DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Admin metadata-only review (does not change PaymentStatus or move money).
  adminReviewStatus     PaymentAdminReviewStatus     @default(NONE)
  adminReviewDecision   PaymentAdminReviewDecision?
  adminReviewNote       String?
  adminReviewAt         DateTime?
  adminReviewByUserId   String?                      @db.Uuid
  adminReviewBy         User?                        @relation("PaymentIntentAdminReviewer", fields: [adminReviewByUserId], references: [id], onDelete: SetNull)

  payouts       Payout[]
  ledgerEntries LedgerEntry[]

  @@index([orderId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
  @@index([adminReviewStatus])
  @@index([adminReviewAt])
  @@index([adminReviewByUserId])
  @@map("payment_intents")
}

// Wayler payout linked to a payment intent (provider transfer in a later batch).
model Payout {
  id                String          @id @default(uuid()) @db.Uuid
  paymentIntentId   String?         @db.Uuid
  paymentIntent     PaymentIntent?  @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  userId            String          @db.Uuid
  user              User            @relation("PayoutUser", fields: [userId], references: [id], onDelete: Restrict)
  status            PayoutStatus    @default(PENDING)
  currency          String
  amount            Decimal         @db.Decimal(12, 2)
  provider          PaymentProvider @default(MANUAL)
  providerPayoutId  String?
  processedAt       DateTime?
  paidAt            DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  ledgerEntries LedgerEntry[]

  @@index([paymentIntentId])
  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
  @@map("payouts")
}

// Immutable ledger line for payment/escrow audit trail (append-only in later batches).
model LedgerEntry {
  id              String          @id @default(uuid()) @db.Uuid
  paymentIntentId String?         @db.Uuid
  paymentIntent   PaymentIntent?  @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  payoutId        String?         @db.Uuid
  payout          Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  orderId         String?         @db.Uuid
  order           DeliveryOrder?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  userId          String?         @db.Uuid
  user            User?           @relation("LedgerEntryUser", fields: [userId], references: [id], onDelete: SetNull)
  type            LedgerEntryType
  currency        String
  amount          Decimal         @db.Decimal(12, 2)
  description     String?
  createdAt       DateTime        @default(now())

  @@index([paymentIntentId])
  @@index([payoutId])
  @@index([orderId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("ledger_entries")
}

// Per-order dispute opened by Sender or Wayler (arbitration routes land in a later batch).
model Dispute {
  id                   String             @id @default(uuid()) @db.Uuid
  orderId              String             @db.Uuid
  order                DeliveryOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  openedById           String             @db.Uuid
  openedBy             User               @relation("DisputesOpened", fields: [openedById], references: [id], onDelete: Restrict)
  assignedArbitratorId String?            @db.Uuid
  assignedArbitrator   User?              @relation("DisputesAssigned", fields: [assignedArbitratorId], references: [id], onDelete: SetNull)
  status               DisputeStatus      @default(OPEN)
  reason               DisputeReason
  description          String
  resolution           DisputeResolution?
  resolutionNote       String?
  resolvedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  messages  DisputeMessage[]
  evidence  DisputeEvidence[]

  @@index([orderId])
  @@index([openedById])
  @@index([assignedArbitratorId])
  @@index([status])
  @@index([reason])
  @@index([createdAt])
  @@map("disputes")
}

model DisputeMessage {
  id        String   @id @default(uuid()) @db.Uuid
  disputeId String   @db.Uuid
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId  String   @db.Uuid
  sender    User     @relation("DisputeMessagesSent", fields: [senderId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime @default(now())

  @@index([disputeId])
  @@index([senderId])
  @@index([createdAt])
  @@map("dispute_messages")
}

model DisputeEvidence {
  id            String   @id @default(uuid()) @db.Uuid
  disputeId     String   @db.Uuid
  dispute       Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  submittedById String   @db.Uuid
  submittedBy   User     @relation("DisputeEvidenceSubmitted", fields: [submittedById], references: [id], onDelete: Restrict)
  title         String
  description   String?
  fileUrl       String?
  createdAt     DateTime @default(now())

  @@index([disputeId])
  @@index([submittedById])
  @@index([createdAt])
  @@map("dispute_evidence")
}

// Wayler-published local availability or trip route for marketplace discovery (API lands in a later batch).
model WaylerAvailability {
  id       String @id @default(uuid()) @db.Uuid
  waylerId String @db.Uuid
  wayler   User   @relation("WaylerAvailabilities", fields: [waylerId], references: [id], onDelete: Cascade)

  type   WaylerAvailabilityType
  status WaylerAvailabilityStatus @default(DRAFT)

  originCountry      String?
  originCity         String?
  originRegion       String?
  destinationCountry String?
  destinationCity    String?
  destinationRegion  String?

  availableFrom DateTime
  availableTo   DateTime?
  departureDate DateTime?
  returnDate    DateTime?

  tripDirection TripDirection?

  maxPackages Int?
  maxWeightKg Decimal? @db.Decimal(8, 2)
  notes       String?

  isPublic    Boolean   @default(false)
  publishedAt DateTime?
  pausedAt    DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([waylerId])
  @@index([type])
  @@index([status])
  @@index([isPublic])
  @@index([originCountry])
  @@index([originCity])
  @@index([originRegion])
  @@index([destinationCountry])
  @@index([destinationCity])
  @@index([destinationRegion])
  @@index([availableFrom])
  @@index([availableTo])
  @@index([departureDate])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("wayler_availabilities")

  availabilityRequests WaylerAvailabilityRequest[]
}

// Sender delivery request sent to a published Wayler availability/trip (API/UI land in a later batch).
model WaylerAvailabilityRequest {
  id             String @id @default(uuid()) @db.Uuid
  availabilityId String @db.Uuid
  availability   WaylerAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  senderId String @db.Uuid
  sender   User   @relation("AvailabilityRequestSender", fields: [senderId], references: [id], onDelete: Cascade)

  waylerId String @db.Uuid
  wayler   User   @relation("AvailabilityRequestWayler", fields: [waylerId], references: [id], onDelete: Cascade)

  status WaylerAvailabilityRequestStatus @default(PENDING)

  title              String
  packageDescription String

  pickupCountry  String
  pickupCity     String
  pickupAddress  String?

  dropoffCountry  String
  dropoffCity     String
  dropoffAddress  String?

  desiredPickupFrom    DateTime?
  desiredPickupTo      DateTime?
  desiredDeliveryFrom  DateTime?
  desiredDeliveryTo    DateTime?

  proposedRewardCents Int
  currency            String @default("EUR")

  message         String?
  responseMessage String?

  acceptedAt  DateTime?
  declinedAt  DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveryOrder DeliveryOrder?

  @@index([availabilityId])
  @@index([senderId])
  @@index([waylerId])
  @@index([status])
  @@index([createdAt])
  @@index([waylerId, status])
  @@index([senderId, status])
  @@index([availabilityId, status])
  @@map("wayler_availability_requests")
}

// Daily Wayler work access fee pass — gates accept/contact/chat until paid (API/paywall land in a later batch).
// accessDate is the normalized calendar day (day-start UTC) the pass covers; one pass per Wayler per day.
model WaylerAccessPass {
  id       String @id @default(uuid()) @db.Uuid
  waylerId String @db.Uuid
  wayler   User   @relation("WaylerAccessPasses", fields: [waylerId], references: [id], onDelete: Cascade)

  status   WaylerAccessPassStatus   @default(PENDING)
  provider WaylerAccessPassProvider @default(MANUAL)
  currency String                   @default("EUR")
  amount   Decimal                  @default(1.00) @db.Decimal(12, 2)
  providerPaymentId String?

  accessDate DateTime
  startsAt   DateTime
  expiresAt  DateTime

  activatedAt DateTime?
  cancelledAt DateTime?
  refundedAt  DateTime?
  failedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([waylerId, accessDate])
  @@index([waylerId])
  @@index([status])
  @@index([provider])
  @@index([accessDate])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("wayler_access_passes")
}

// Append-only admin/arbitrator operator action log (v1: KYC + dispute mutations).
model AdminAuditLog {
  id                   String                @id @default(uuid()) @db.Uuid
  actorUserId          String                @db.Uuid
  actor                User                  @relation("AdminAuditLogActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  actorEmailSnapshot   String
  actorDisplaySnapshot String
  actorRolesSnapshot   UserRole[]
  action               AdminAuditLogAction
  targetType           AdminAuditLogTargetType
  targetId             String                @db.Uuid
  targetUserId         String?               @db.Uuid
  status               AdminAuditLogStatus   @default(SUCCESS)
  summary              String
  metadata             Json?
  requestId            String?
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime              @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([targetUserId])
  @@map("admin_audit_logs")
}

// User support tickets (Support Ticket foundation v1 — not emergency response).
model SupportTicket {
  id                   String                 @id @default(uuid()) @db.Uuid
  userId               String                 @db.Uuid
  user                 User                   @relation("SupportTicketsOwned", fields: [userId], references: [id], onDelete: Cascade)
  orderId              String?                @db.Uuid
  order                DeliveryOrder?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  subject              String
  message              String
  category             SupportTicketCategory
  status               SupportTicketStatus    @default(OPEN)
  priority             SupportTicketPriority  @default(NORMAL)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  closedAt             DateTime?
  adminNote            String?
  lastAdminActionAt    DateTime?
  lastAdminActionById  String?                @db.Uuid
  lastAdminActionBy    User?                  @relation("SupportTicketAdminActions", fields: [lastAdminActionById], references: [id], onDelete: SetNull)
  messages             SupportTicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
  @@index([orderId])
  @@map("support_tickets")
}

// Threaded replies on support tickets (v1 — in-app only, no attachments).
model SupportTicketMessage {
  id         String                         @id @default(uuid()) @db.Uuid
  ticketId   String                         @db.Uuid
  ticket     SupportTicket                  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String                         @db.Uuid
  author     User                           @relation("SupportTicketMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  authorRole SupportTicketMessageAuthorRole
  body       String
  isInternal Boolean                        @default(false)
  createdAt  DateTime                       @default(now())
  updatedAt  DateTime                       @updatedAt

  @@index([ticketId])
  @@index([authorId])
  @@index([ticketId, createdAt])
  @@index([authorRole])
  @@index([isInternal])
  @@map("support_ticket_messages")
}

// Post-delivery user-submitted trust reviews (v1 — not verified identity or safety guarantees).
model Review {
  id           String          @id @default(uuid()) @db.Uuid
  orderId      String          @db.Uuid
  order        DeliveryOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewerId   String          @db.Uuid
  reviewer     User            @relation("ReviewsWritten", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId   String          @db.Uuid
  reviewee     User            @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewerRole ReviewPartyRole
  revieweeRole ReviewPartyRole
  rating       Int
  comment      String?
  tags         String[]        @default([])
  isHidden     Boolean         @default(false)
  hiddenAt     DateTime?
  hiddenById   String?         @db.Uuid
  hiddenBy     User?           @relation("ReviewHiddenBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  adminNote    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([orderId, reviewerId, revieweeId])
  @@index([orderId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([rating])
  @@index([isHidden])
  @@index([createdAt])
  @@map("reviews")
}
