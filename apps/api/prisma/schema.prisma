// Wayly — Prisma schema.
//
// M1: User, RefreshToken, PasswordResetToken.
// M2 Batch 1: KycVerification (provider integration lands in a later batch).
// M4 Batch 1: DeliveryOrder foundation (API/UI land in later batches).
// Notification foundation (routes/dispatch land in a later batch).
// Chat foundation (routes/WebSocket land in a later batch).
// Payment/escrow foundation (routes/Stripe land in a later batch).
// Wayler availability / trip listing foundation (routes/discovery UI land in a later batch).
// Dispute/arbitration foundation (routes/admin UI land in a later batch).
//
// PostGIS is enabled because local city-delivery feed/search relies on
// geographic radius queries (geography(Point)) from M4/M5.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// --- Enums (mirror @wayly/types) ---------------------------------------------

// Authorization roles. "Sender"/"Wayler" are contextual modes, NOT roles.
enum UserRole {
  USER
  ADMIN
  ARBITRATOR
}

// KYC verification status; gates core activity until APPROVED (enforced in M2+).
enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

// Delivery request lifecycle (M4 foundation; transitions enforced in later batches).
enum DeliveryOrderStatus {
  DRAFT
  OPEN
  ACCEPTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DISPUTED
}

enum DeliveryOrderType {
  LOCAL
  INTERNATIONAL
}

enum PackageSize {
  SMALL
  MEDIUM
  LARGE
  OVERSIZED
}

// In-app notification categories (dispatch/WebSocket land in a later batch).
enum NotificationType {
  ORDER_PUBLISHED
  ORDER_ACCEPTED
  ORDER_IN_TRANSIT
  ORDER_DELIVERED
  ORDER_CANCELLED
  PROOF_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  SYSTEM
}

// Payment intent lifecycle (Stripe/manual processing lands in a later batch).
enum PaymentStatus {
  PENDING
  AUTHORIZED
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  OTHER
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum LedgerEntryType {
  PAYMENT_AUTHORIZED
  ESCROW_HELD
  PLATFORM_FEE_CHARGED
  PAYOUT_CREATED
  PAYOUT_PAID
  REFUND_CREATED
  ADJUSTMENT
}

// Dispute lifecycle (API/arbitrator UI land in a later batch).
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
  CANCELLED
}

enum DisputeReason {
  ITEM_NOT_DELIVERED
  ITEM_DAMAGED
  WRONG_ITEM
  PAYMENT_ISSUE
  SAFETY_CONCERN
  OTHER
}

enum DisputeResolution {
  REFUND_SENDER
  RELEASE_TO_WAYLER
  PARTIAL_REFUND
  NO_ACTION
  OTHER
}

// Wayler-published availability or travel route (API/discovery land in a later batch).
enum WaylerAvailabilityStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum WaylerAvailabilityType {
  LOCAL_AVAILABILITY
  TRIP_ROUTE
}

enum TripDirection {
  ONE_WAY
  RETURN
  FLEXIBLE
}

// --- Models ------------------------------------------------------------------

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  roles        UserRole[] @default([USER])

  // KYC / verification (provider integration lands in M2).
  verified      Boolean   @default(false)
  kycStatus     KycStatus @default(NONE)
  phoneVerified Boolean   @default(false)

  // Payments / payouts (Stripe integration lands in M8).
  stripeCustomerId       String? @unique
  stripeConnectAccountId String? @unique
  connectOnboarded       Boolean @default(false)

  locale  String  @default("en")
  country String?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?
  gdprDeletionRequestedAt DateTime?

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  kycVerifications    KycVerification[]
  sentDeliveryOrders            DeliveryOrder[] @relation("SentDeliveryOrders")
  acceptedDeliveryOrders        DeliveryOrder[] @relation("AcceptedDeliveryOrders")
  proofSubmittedDeliveryOrders  DeliveryOrder[] @relation("ProofSubmittedDeliveryOrders")
  notifications                 Notification[]
  sentConversations             Conversation[] @relation("ConversationSender")
  waylerConversations           Conversation[] @relation("ConversationWayler")
  chatMessages                  ChatMessage[]  @relation("ChatMessageSender")
  paymentIntentsAsPayer         PaymentIntent[] @relation("PaymentIntentPayer")
  paymentIntentsAsPayee         PaymentIntent[] @relation("PaymentIntentPayee")
  payouts                       Payout[]        @relation("PayoutUser")
  ledgerEntries                 LedgerEntry[]   @relation("LedgerEntryUser")
  disputesOpened                Dispute[]       @relation("DisputesOpened")
  disputesAssigned              Dispute[]       @relation("DisputesAssigned")
  disputeMessages               DisputeMessage[] @relation("DisputeMessagesSent")
  disputeEvidence               DisputeEvidence[] @relation("DisputeEvidenceSubmitted")
  waylerAvailabilities          WaylerAvailability[] @relation("WaylerAvailabilities")

  @@index([deletedAt])
  @@map("users")
}

// Refresh tokens are stored ONLY as hashes (never the raw token), with a
// familyId to support rotation + reuse detection.
model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique
  familyId          String    @db.Uuid
  userAgent         String?
  ip                String?
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?   @db.Uuid
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// Password reset tokens are stored ONLY as hashes.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// KYC verification attempts (Sumsub/manual providers wired in a later batch).
// User.kycStatus / User.verified remain denormalized quick-access fields.
model KycVerification {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status              KycStatus @default(PENDING)
  provider            String?
  providerApplicantId String?   @unique
  providerReviewId    String?
  levelName           String?
  country             String?
  documentType        String?
  rejectionReason     String?
  rawProviderPayload  Json?
  submittedAt         DateTime?
  reviewedAt          DateTime?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("kyc_verifications")
}

// P2P delivery request posted by a Sender; optionally accepted by a Wayler (M4 foundation).
model DeliveryOrder {
  id               String              @id @default(uuid()) @db.Uuid
  senderId         String              @db.Uuid
  sender           User                @relation("SentDeliveryOrders", fields: [senderId], references: [id], onDelete: Restrict)
  acceptedWaylerId String?             @db.Uuid
  acceptedWayler   User?               @relation("AcceptedDeliveryOrders", fields: [acceptedWaylerId], references: [id], onDelete: SetNull)
  status           DeliveryOrderStatus @default(DRAFT)
  type             DeliveryOrderType
  title            String
  description      String?
  packageSize      PackageSize?
  packageWeightKg  Decimal?            @db.Decimal(8, 2)

  pickupCountry     String?
  pickupCity        String?
  pickupAddressText String?
  pickupLat         Decimal? @db.Decimal(10, 7)
  pickupLng         Decimal? @db.Decimal(10, 7)

  dropoffCountry     String?
  dropoffCity        String?
  dropoffAddressText String?
  dropoffLat         Decimal? @db.Decimal(10, 7)
  dropoffLng         Decimal? @db.Decimal(10, 7)

  pickupDateFrom   DateTime?
  pickupDateTo     DateTime?
  deliveryDeadline DateTime?

  currency             String   @default("USD")
  offeredRewardAmount  Decimal? @db.Decimal(10, 2)
  escrowRequired       Boolean  @default(true)
  notes                String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  acceptedAt  DateTime?
  cancelledAt DateTime?
  deliveredAt DateTime?

  // Proof-of-delivery metadata (Wayler-submitted; photo/signature URLs in later batches).
  proofNote              String?
  proofConfirmationCode  String?
  proofSubmittedAt       DateTime?
  proofSubmittedById     String?   @db.Uuid
  proofSubmittedBy       User?     @relation("ProofSubmittedDeliveryOrders", fields: [proofSubmittedById], references: [id], onDelete: SetNull)
  notifications          Notification[]
  conversation           Conversation?
  paymentIntent          PaymentIntent?
  ledgerEntries          LedgerEntry[]
  disputes               Dispute[]

  @@index([senderId])
  @@index([acceptedWaylerId])
  @@index([status])
  @@index([type])
  @@index([pickupCountry])
  @@index([pickupCity])
  @@index([dropoffCountry])
  @@index([dropoffCity])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([proofSubmittedById])
  @@map("delivery_orders")
}

// In-app notification for a user (email/push/WebSocket dispatch in later batches).
model Notification {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @db.Uuid
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType
  title          String
  body           String?
  relatedOrderId String?          @db.Uuid
  relatedOrder   DeliveryOrder?   @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@index([type])
  @@index([relatedOrderId])
  @@map("notifications")
}

// Order-based chat between Sender and accepted Wayler (API/WebSocket land in a later batch).
model Conversation {
  id        String        @id @default(uuid()) @db.Uuid
  orderId   String        @unique @db.Uuid
  order     DeliveryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String        @db.Uuid
  sender    User          @relation("ConversationSender", fields: [senderId], references: [id], onDelete: Cascade)
  waylerId  String        @db.Uuid
  wayler    User          @relation("ConversationWayler", fields: [waylerId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages ChatMessage[]

  @@index([senderId])
  @@index([waylerId])
  @@index([orderId])
  @@index([createdAt])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @db.Uuid
  sender         User         @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([readAt])
  @@map("chat_messages")
}

// Per-order payment intent (one per delivery order; escrow/Stripe in later batches).
model PaymentIntent {
  id                String          @id @default(uuid()) @db.Uuid
  orderId           String          @unique @db.Uuid
  order             DeliveryOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payerId           String          @db.Uuid
  payer             User            @relation("PaymentIntentPayer", fields: [payerId], references: [id], onDelete: Restrict)
  payeeId           String?         @db.Uuid
  payee             User?           @relation("PaymentIntentPayee", fields: [payeeId], references: [id], onDelete: SetNull)
  provider          PaymentProvider @default(MANUAL)
  status            PaymentStatus   @default(PENDING)
  currency          String
  amount            Decimal         @db.Decimal(12, 2)
  platformFeeAmount Decimal?        @db.Decimal(12, 2)
  escrowAmount      Decimal?        @db.Decimal(12, 2)
  providerPaymentId String?
  authorizedAt      DateTime?
  escrowedAt        DateTime?
  releasedAt        DateTime?
  refundedAt        DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  payouts       Payout[]
  ledgerEntries LedgerEntry[]

  @@index([orderId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
  @@map("payment_intents")
}

// Wayler payout linked to a payment intent (provider transfer in a later batch).
model Payout {
  id                String          @id @default(uuid()) @db.Uuid
  paymentIntentId   String?         @db.Uuid
  paymentIntent     PaymentIntent?  @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  userId            String          @db.Uuid
  user              User            @relation("PayoutUser", fields: [userId], references: [id], onDelete: Restrict)
  status            PayoutStatus    @default(PENDING)
  currency          String
  amount            Decimal         @db.Decimal(12, 2)
  provider          PaymentProvider @default(MANUAL)
  providerPayoutId  String?
  processedAt       DateTime?
  paidAt            DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  ledgerEntries LedgerEntry[]

  @@index([paymentIntentId])
  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
  @@map("payouts")
}

// Immutable ledger line for payment/escrow audit trail (append-only in later batches).
model LedgerEntry {
  id              String          @id @default(uuid()) @db.Uuid
  paymentIntentId String?         @db.Uuid
  paymentIntent   PaymentIntent?  @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  payoutId        String?         @db.Uuid
  payout          Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  orderId         String?         @db.Uuid
  order           DeliveryOrder?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  userId          String?         @db.Uuid
  user            User?           @relation("LedgerEntryUser", fields: [userId], references: [id], onDelete: SetNull)
  type            LedgerEntryType
  currency        String
  amount          Decimal         @db.Decimal(12, 2)
  description     String?
  createdAt       DateTime        @default(now())

  @@index([paymentIntentId])
  @@index([payoutId])
  @@index([orderId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("ledger_entries")
}

// Per-order dispute opened by Sender or Wayler (arbitration routes land in a later batch).
model Dispute {
  id                   String             @id @default(uuid()) @db.Uuid
  orderId              String             @db.Uuid
  order                DeliveryOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  openedById           String             @db.Uuid
  openedBy             User               @relation("DisputesOpened", fields: [openedById], references: [id], onDelete: Restrict)
  assignedArbitratorId String?            @db.Uuid
  assignedArbitrator   User?              @relation("DisputesAssigned", fields: [assignedArbitratorId], references: [id], onDelete: SetNull)
  status               DisputeStatus      @default(OPEN)
  reason               DisputeReason
  description          String
  resolution           DisputeResolution?
  resolutionNote       String?
  resolvedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  messages  DisputeMessage[]
  evidence  DisputeEvidence[]

  @@index([orderId])
  @@index([openedById])
  @@index([assignedArbitratorId])
  @@index([status])
  @@index([reason])
  @@index([createdAt])
  @@map("disputes")
}

model DisputeMessage {
  id        String   @id @default(uuid()) @db.Uuid
  disputeId String   @db.Uuid
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId  String   @db.Uuid
  sender    User     @relation("DisputeMessagesSent", fields: [senderId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime @default(now())

  @@index([disputeId])
  @@index([senderId])
  @@index([createdAt])
  @@map("dispute_messages")
}

model DisputeEvidence {
  id            String   @id @default(uuid()) @db.Uuid
  disputeId     String   @db.Uuid
  dispute       Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  submittedById String   @db.Uuid
  submittedBy   User     @relation("DisputeEvidenceSubmitted", fields: [submittedById], references: [id], onDelete: Restrict)
  title         String
  description   String?
  fileUrl       String?
  createdAt     DateTime @default(now())

  @@index([disputeId])
  @@index([submittedById])
  @@index([createdAt])
  @@map("dispute_evidence")
}

// Wayler-published local availability or trip route for marketplace discovery (API lands in a later batch).
model WaylerAvailability {
  id       String @id @default(uuid()) @db.Uuid
  waylerId String @db.Uuid
  wayler   User   @relation("WaylerAvailabilities", fields: [waylerId], references: [id], onDelete: Cascade)

  type   WaylerAvailabilityType
  status WaylerAvailabilityStatus @default(DRAFT)

  originCountry      String?
  originCity         String?
  originRegion       String?
  destinationCountry String?
  destinationCity    String?
  destinationRegion  String?

  availableFrom DateTime
  availableTo   DateTime?
  departureDate DateTime?
  returnDate    DateTime?

  tripDirection TripDirection?

  maxPackages Int?
  maxWeightKg Decimal? @db.Decimal(8, 2)
  notes       String?

  isPublic    Boolean   @default(false)
  publishedAt DateTime?
  pausedAt    DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([waylerId])
  @@index([type])
  @@index([status])
  @@index([isPublic])
  @@index([originCountry])
  @@index([originCity])
  @@index([originRegion])
  @@index([destinationCountry])
  @@index([destinationCity])
  @@index([destinationRegion])
  @@index([availableFrom])
  @@index([availableTo])
  @@index([departureDate])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("wayler_availabilities")
}
