{
  "name": "wayly",
  "version": "0.0.0",
  "private": true,
  "description": "Wayly — cross-platform P2P delivery platform (monorepo).",
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20 <21",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "build": "turbo run build --concurrency=1",
    "dev": "turbo run dev",
    "lint": "turbo run lint --concurrency=1",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,md,yaml,yml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,md,yaml,yml,css}\"",
    "clean": "turbo run clean",
    "docker:up": "docker compose -f infra/compose/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infra/compose/docker-compose.dev.yml down",
    "demo:seed": "pnpm --dir apps/api seed:demo",
    "demo:check": "pnpm --dir apps/api seed:demo:check",
    "demo:smoke": "pnpm --dir apps/api demo:smoke",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@wayly/config-eslint": "workspace:*",
    "@wayly/config-tsconfig": "workspace:*",
    "eslint": "catalog:",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "catalog:",
    "turbo": "^2.1.3",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  }
}
